const express = require('express');
const cors = require('cors');
const fs = require('fs');
const app = express();
const PORT = 3000;

app.use(cors());

app.get('/api/kamus', (req, res) => {
    try {
        const kataKunci = req.query.kata.toLowerCase().trim();
        const dataMentah = fs.readFileSync('data.json', 'utf8');
        const kamus = JSON.parse(dataMentah);

        const hasil = kamus.find(item => 
            item.latin.toLowerCase() === kataKunci || 
            item.indonesia.toLowerCase() === kataKunci
        );

        if (hasil) {
            res.json({ status: "sukses", data: hasil });
        } else {
            res.status(404).json({ status: "gagal", pesan: "Kata tidak ditemukan" });
        }
    } catch (error) {
        res.status(500).json({ status: "error", pesan: "Gagal membaca database" });
    }
});

app.listen(PORT, () => {
    console.log(Backend Kamus aktif di http://localhost:${PORT});
});
